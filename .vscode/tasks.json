{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Release: Tag and push new version",
            "type": "shell",
            "command": "bash ${workspaceFolder}/scripts/release.sh",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "Docker: Build image locally",
            "type": "shell",
            "command": "docker compose build",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Docker: Run build (one-shot)",
            "type": "shell",
            "command": "docker compose up --build",
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
