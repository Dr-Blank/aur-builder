{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Release: Tag and push new version",
            "type": "shell",
            "command": "bash ${workspaceFolder}/scripts/release.sh",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "Docker: Build image (local)",
            "type": "shell",
            "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml build",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Docker: Run one-shot (local build, no chroot)",
            "type": "shell",
            "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml run --rm -e PACKAGES=${input:testPackages} aur-builder",
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "Docker: Run scheduled mode (local build)",
            "type": "shell",
            "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "testPackages",
            "type": "promptString",
            "description": "Space-separated AUR package names to build",
            "default": "yay"
        }
    ]
}
