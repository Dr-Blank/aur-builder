{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Release: Tag and push new version",
            "type": "shell",
            "command": "bash ${workspaceFolder}/scripts/release.sh",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "Docker: Build image locally",
            "type": "shell",
            "command": "docker compose build",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Docker: Run build (one-shot)",
            "type": "shell",
            "command": "docker compose up --build",
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Test: Build image and run with USE_CHROOT=0",
            "type": "shell",
            "command": "mkdir -p ${workspaceFolder}/repo && rm -f ${workspaceFolder}/repo/*.lck && docker build -t aur-builder ${workspaceFolder} && docker run --rm --privileged -v ${workspaceFolder}/repo:/repo -e USE_CHROOT=0 -e PACKAGES=${input:testPackages} aur-builder",
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        }
    ],
    "inputs": [
        {
            "id": "testPackages",
            "type": "promptString",
            "description": "Space-separated AUR package names to build",
            "default": "yay"
        }
    ]
}
